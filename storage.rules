rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — only the owner can write; anyone authenticated can read
    match /photos/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Verification documents — only the owner can write; admins read via backend
    match /documents/{uid}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
